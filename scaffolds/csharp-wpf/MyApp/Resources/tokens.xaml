<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

  <!-- ====================================================================
       tokens.xaml — design-system mirror for WPF
       Colours, spacing, radius, typography, and motion mirror the
       canonical web design-system (libraries/design-system/tokens/).
       Edit the palette per project; keep the keys stable.
       ==================================================================== -->

  <!-- Surfaces (design-system surface scale 1..5) -->
  <SolidColorBrush x:Key="PageBg"           Color="#000000"/>
  <SolidColorBrush x:Key="PanelBg"          Color="#0A0D10"/>
  <SolidColorBrush x:Key="CardBg"           Color="#11161B"/>
  <SolidColorBrush x:Key="ElevatedBg"       Color="#171D24"/>
  <SolidColorBrush x:Key="InteractiveBg"    Color="#171D24"/>
  <SolidColorBrush x:Key="InteractiveHover" Color="#1D252D"/>

  <!-- Text -->
  <SolidColorBrush x:Key="Text"      Color="#F4F7FA"/>
  <SolidColorBrush x:Key="TextMuted" Color="#B4BDC7"/>
  <SolidColorBrush x:Key="TextFaint" Color="#87919C"/>

  <!-- Lines -->
  <SolidColorBrush x:Key="Border"       Color="#232C35"/>
  <SolidColorBrush x:Key="BorderStrong" Color="#313C48"/>
  <SolidColorBrush x:Key="BorderSoft"   Color="#1A2128"/>

  <!-- Accent + semantic (design-system accent + semantic colours) -->
  <SolidColorBrush x:Key="Accent"       Color="#7C9AB3"/>
  <SolidColorBrush x:Key="AccentStrong" Color="#90ADC5"/>
  <SolidColorBrush x:Key="AccentSoft"   Color="#297C9AB3"/>  <!-- 16% -->
  <SolidColorBrush x:Key="Success"      Color="#7D9E8A"/>
  <SolidColorBrush x:Key="Warning"      Color="#A79A74"/>
  <SolidColorBrush x:Key="Danger"       Color="#A1837F"/>
  <SolidColorBrush x:Key="Info"         Color="#7F92A3"/>
  <SolidColorBrush x:Key="FocusRing"    Color="#6190ADC5"/>  <!-- 38% -->

  <!-- Spacing (DIP; design-system space scale) -->
  <sys:Double x:Key="Space1">4</sys:Double>
  <sys:Double x:Key="Space2">8</sys:Double>
  <sys:Double x:Key="Space3">12</sys:Double>
  <sys:Double x:Key="Space4">16</sys:Double>
  <sys:Double x:Key="Space5">24</sys:Double>
  <sys:Double x:Key="Space6">32</sys:Double>
  <Thickness x:Key="CardPadding">16</Thickness>

  <!-- Radius (design-system radius sm/md/lg) -->
  <CornerRadius x:Key="RadiusSm">8</CornerRadius>
  <CornerRadius x:Key="RadiusMd">12</CornerRadius>
  <CornerRadius x:Key="RadiusLg">16</CornerRadius>

  <!-- Typography (design-system text scale) -->
  <FontFamily x:Key="FontSans">Segoe UI Variable, Segoe UI, sans-serif</FontFamily>
  <FontFamily x:Key="FontMono">Cascadia Mono, Consolas, monospace</FontFamily>
  <sys:Double x:Key="TextXs">12</sys:Double>
  <sys:Double x:Key="TextSm">14</sys:Double>
  <sys:Double x:Key="TextMd">16</sys:Double>
  <sys:Double x:Key="TextLg">18</sys:Double>
  <sys:Double x:Key="TextXl">20</sys:Double>
  <sys:Double x:Key="Text2xl">28</sys:Double>

  <!-- Motion (design-system duration scale) -->
  <Duration x:Key="DurationFast">0:0:0.12</Duration>
  <Duration x:Key="DurationBase">0:0:0.18</Duration>
  <Duration x:Key="DurationSlow">0:0:0.26</Duration>

  <!-- Card drop shadow -->
  <DropShadowEffect x:Key="CardShadow" BlurRadius="24" ShadowDepth="8"
                    Direction="270" Opacity="0.18" Color="#000000"/>

  <!-- Keyboard-only focus ring: renders for keyboard navigation, never
       for mouse clicks. -->
  <Style x:Key="ActionFocusVisual">
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate>
          <Border CornerRadius="8" BorderThickness="1.5"
                  BorderBrush="{StaticResource AccentStrong}" Margin="-1.5"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Quiet action: the default button. -->
  <Style x:Key="QuietAction" TargetType="Button">
    <Setter Property="FocusVisualStyle" Value="{StaticResource ActionFocusVisual}"/>
    <Setter Property="Foreground" Value="{StaticResource Text}"/>
    <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="10,6"/>
    <Setter Property="FontSize" Value="{StaticResource TextSm}"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="b" CornerRadius="8"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  Padding="{TemplateBinding Padding}">
            <Border.Background><SolidColorBrush Color="#171D24"/></Border.Background>
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard><Storyboard>
                  <ColorAnimation Storyboard.TargetName="b" Storyboard.TargetProperty="Background.Color"
                                  To="#1D252D" Duration="0:0:0.12"/>
                </Storyboard></BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard><Storyboard>
                  <ColorAnimation Storyboard.TargetName="b" Storyboard.TargetProperty="Background.Color"
                                  To="#171D24" Duration="0:0:0.12"/>
                </Storyboard></BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard><Storyboard>
                  <DoubleAnimation Storyboard.TargetName="b" Storyboard.TargetProperty="Opacity"
                                   To="0.85" Duration="0:0:0.12"/>
                </Storyboard></BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard><Storyboard>
                  <DoubleAnimation Storyboard.TargetName="b" Storyboard.TargetProperty="Opacity"
                                   To="1" Duration="0:0:0.12"/>
                </Storyboard></BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Primary action: the one accent button per surface. -->
  <Style x:Key="PrimaryAction" TargetType="Button">
    <Setter Property="FocusVisualStyle" Value="{StaticResource ActionFocusVisual}"/>
    <Setter Property="Foreground" Value="{StaticResource PageBg}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="14,7"/>
    <Setter Property="FontSize" Value="{StaticResource TextSm}"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="b" CornerRadius="8" Padding="{TemplateBinding Padding}">
            <Border.Background><SolidColorBrush Color="#7C9AB3"/></Border.Background>
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard><Storyboard>
                  <ColorAnimation Storyboard.TargetName="b" Storyboard.TargetProperty="Background.Color"
                                  To="#90ADC5" Duration="0:0:0.12"/>
                </Storyboard></BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard><Storyboard>
                  <ColorAnimation Storyboard.TargetName="b" Storyboard.TargetProperty="Background.Color"
                                  To="#7C9AB3" Duration="0:0:0.12"/>
                </Storyboard></BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Dark text input with a placeholder hint (set via Tag). -->
  <Style TargetType="TextBox">
    <Setter Property="Background" Value="{StaticResource InteractiveBg}"/>
    <Setter Property="Foreground" Value="{StaticResource Text}"/>
    <Setter Property="CaretBrush" Value="{StaticResource Text}"/>
    <Setter Property="MinHeight" Value="34"/>
    <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="8,6"/>
    <Setter Property="FontSize" Value="{StaticResource TextSm}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Border x:Name="bd" Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
            <Grid>
              <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                            VerticalAlignment="Center"/>
              <TextBlock x:Name="hint" Text="{TemplateBinding Tag}"
                         Foreground="{StaticResource TextFaint}"
                         Margin="{TemplateBinding Padding}" VerticalAlignment="Center"
                         IsHitTestVisible="False" Visibility="Collapsed"/>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="Text" Value=""/>
                <Condition Property="IsKeyboardFocused" Value="False"/>
              </MultiTrigger.Conditions>
              <Setter TargetName="hint" Property="Visibility" Value="Visible"/>
            </MultiTrigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentStrong}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>
